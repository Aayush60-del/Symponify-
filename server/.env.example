MONGO_URI=mongodb://localhost:27017/symponify
JWT_SECRET=replace_with_a_secure_secret
PORT=5000
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Admin credentials (used for initial setup/seed)
ADMIN_NAME=Symponify Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_a_secure_admin_password

# Cloudinary configuration (required for all uploads)
# Get these from https://cloudinary.com/console/settings/api-keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

