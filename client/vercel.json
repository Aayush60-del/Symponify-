{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://symponify.onrender.com/api/:path*"
    },
    {
      "source": "/songs/:path*",
      "destination": "https://symponify.onrender.com/songs/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
